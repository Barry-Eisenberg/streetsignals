{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://streetsignals.nextfiadvisors.com/schemas/initiative-taxonomy.schema.json",
  "title": "Street Signals Initiative Taxonomy",
  "type": "object",
  "required": [
    "version",
    "canonicalInitiatives",
    "aliasMap"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "canonicalInitiatives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "group",
          "description",
          "isMatrixCategory"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "group": { "type": "string" },
          "description": { "type": "string" },
          "isMatrixCategory": { "type": "boolean" },
          "active": { "type": "boolean", "default": true }
        }
      }
    },
    "aliasMap": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "alias",
          "canonicalId",
          "mappingType"
        ],
        "properties": {
          "alias": { "type": "string" },
          "canonicalId": { "type": "string" },
          "mappingType": {
            "type": "string",
            "enum": ["exact", "synonym", "manual", "heuristic"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
